generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

model Municipality {
  id               String                     @id @default(cuid())
  code             String                     @unique
  name             String
  slug             String                     @unique
  mapX             Float?
  mapY             Float?
  teaser           String?
  isActive         Boolean                    @default(true)
  homeMapVisible   Boolean                    @default(false)
  homeMapAttractMode Boolean                  @default(false)
  homeMapPriority  Int                        @default(999)
  homeMapLabelMode String                     @default("auto")
  homeMapRegionTag String                     @default("other")
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  industryStats    MunicipalityIndustryStat[]
  jobs             Job[]
  jobSourceSnapshots MunicipalityJobSourceSnapshot[]
  savedSearches    SavedSearch[]
  searchFollows    SearchFollow[]

  @@index([slug])
  @@index([name])
  @@index([homeMapVisible, homeMapPriority])
  @@index([homeMapAttractMode, homeMapPriority])
}

model Industry {
  id                String                     @id @default(cuid())
  code              String                     @unique
  slug              String                     @unique
  nameDa            String
  nameEn            String?
  icon              String?
  accentColor       String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  municipalityStats MunicipalityIndustryStat[]
  jobSourceCategories MunicipalityJobSourceCategory[]
  jobs              Job[]
  savedSearches     SavedSearch[]
  searchFollows     SearchFollow[]
}

model MunicipalityIndustryStat {
  id             String       @id @default(cuid())
  municipalityId String
  industryId     String
  rank           Int
  jobCount       Int
  isMock         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  industry       Industry     @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([municipalityId, industryId])
  @@index([municipalityId, rank])
  @@index([industryId])
}

model Job {
  id             String       @id @default(cuid())
  municipalityId String
  industryId     String
  title          String
  employerName   String
  locationLabel  String?
  summary        String?
  applyUrl       String?
  language       String       @default("da")
  isMock         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  industry       Industry     @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@index([municipalityId])
  @@index([industryId])
}

model ImportRun {
  id           String                         @id @default(cuid())
  source       String
  sourceTable  String?
  status       String                         @default("running")
  period       String?
  metadata     Json?
  errorMessage String?
  startedAt    DateTime                       @default(now())
  finishedAt   DateTime?
  snapshots    MunicipalityJobSourceSnapshot[]

  @@index([source, startedAt])
  @@index([sourceTable, period])
}

model MunicipalityJobSourceSnapshot {
  id                      String                         @id @default(cuid())
  municipalityId          String
  importRunId            String?
  source                  String
  sourceTable             String
  period                  String
  totalOpenPositions      Int
  dailyAverageOpenPositions Int
  newlyPostedPositions    Int
  fetchedAt               DateTime
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  municipality            Municipality                   @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  importRun               ImportRun?                     @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  categories              MunicipalityJobSourceCategory[]
  topTitles               MunicipalityJobSourceTopTitle[]

  @@unique([municipalityId, source, sourceTable, period])
  @@index([municipalityId, source, sourceTable, period])
  @@index([source, sourceTable, period])
}

model MunicipalityJobSourceCategory {
  id            String                       @id @default(cuid())
  snapshotId    String
  industryId    String
  rank          Int
  openPositions Int
  createdAt     DateTime                     @default(now())
  snapshot      MunicipalityJobSourceSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  industry      Industry                     @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, industryId])
  @@unique([snapshotId, rank])
  @@index([snapshotId, openPositions])
  @@index([industryId])
}

model MunicipalityJobSourceTopTitle {
  id            String                       @id @default(cuid())
  snapshotId     String
  rank           Int
  titleKey       String
  titleLabel     String
  openPositions  Int
  createdAt      DateTime                     @default(now())
  snapshot       MunicipalityJobSourceSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, rank])
  @@index([snapshotId, openPositions])
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  name          String?
  locale        String         @default("da")
  role          UserRole       @default(user)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  savedSearches SavedSearch[]
  searchFollows SearchFollow[]
  auditEvents   AuditEvent[]

  @@index([createdAt])
}

model SavedSearch {
  id             String        @id @default(cuid())
  userId         String
  title          String
  queryText      String?
  filters        Json?
  municipalityId String?
  industryId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipality   Municipality? @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  industry       Industry?     @relation(fields: [industryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model SearchFollow {
  id                  String        @id @default(cuid())
  userId              String
  title               String
  queryText           String?
  filters             Json?
  municipalityId      String?
  industryId          String?
  isActive            Boolean       @default(true)
  notificationChannel String        @default("in_app")
  lastResultHash      String?
  lastCheckedAt       DateTime?
  lastNotifiedAt      DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipality        Municipality? @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  industry            Industry?     @relation(fields: [industryId], references: [id], onDelete: SetNull)

  @@unique([userId, municipalityId, queryText])
  @@index([userId, isActive, createdAt])
}

model AuditEvent {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model JobindsatsTitleTranslation {
  daKey     String   @id
  en        String
  uk        String?
  ar        String?
  fa        String?
  ur        String?
  pl        String?
  de        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}
